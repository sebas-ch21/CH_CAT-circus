# ==============================================================
# Charlie Admissions — Environment Template
# --------------------------------------------------------------
# Copy to `.env` and fill in real values. Values prefixed with
# `VITE_` are inlined into the client bundle by Vite; every
# other name is consumed by Supabase Edge Functions through
# `supabase secrets set`.
# ==============================================================

# --------------------------------------------------------------
# Supabase (required)
# --------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Service-role key lives ONLY on the server — never ship it to
# the client. Set via: `supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...`
# SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------------------
# Integration modes (mock | live). Default = mock so the app
# behaves exactly as today until the engineer flips these.
# --------------------------------------------------------------
VITE_CALENDAR_MODE=mock
VITE_ZOOM_MODE=mock
VITE_OKTA_MODE=mock

# Optional dev-only overrides for feature flags. Values: true|false.
# Leave blank to fall back to the `features` row in `app_settings`.
# VITE_FORCE_FEATURE_CALENDAR_SYNC=
# VITE_FORCE_FEATURE_ZOOM_MEETING_API=
# VITE_FORCE_FEATURE_OKTA_SSO=
# VITE_FORCE_FEATURE_OKTA_SCIM=

# --------------------------------------------------------------
# Google Calendar OAuth  (Feature 1)
#   Docs: https://console.cloud.google.com/apis/credentials
#   Scope required: https://www.googleapis.com/auth/calendar.readonly
# --------------------------------------------------------------
VITE_GOOGLE_OAUTH_CLIENT_ID=
# Server-side secrets (set via `supabase secrets set`):
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_APP/auth/google/callback

# --------------------------------------------------------------
# Zoom Server-to-Server OAuth  (Feature 3)
#   Docs: https://marketplace.zoom.us/develop/create
#   App type: "Server-to-Server OAuth"
#   Scopes  : meeting:write:admin, user:read:admin, room:read:admin,
#             room:write:admin
# --------------------------------------------------------------
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# Default daily meeting creation cap per host (soft limit, DB-enforced):
# ZOOM_DAILY_CREATE_CAP=50

# --------------------------------------------------------------
# Okta OIDC SSO + SCIM  (Feature 4)
#   Docs: https://help.okta.com/oie/en-us/content/topics/apps/apps-add-oidc-apps.htm
#   Supabase Auth SSO requires: domain + client id + client secret
# --------------------------------------------------------------
VITE_OKTA_DOMAIN=
# OKTA_ISSUER=https://YOUR_TENANT.okta.com
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# OKTA_SCIM_BEARER_TOKEN=     # Shared secret Okta sends on SCIM calls
